# Mobile App (Expo) Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets!
#
# These EXPO_PUBLIC_ vars are inlined by Metro at build time.
# Restart Expo after changes: npx expo start --clear

# Your Supabase project URL (from Project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable key (from Project Settings > API > anon/public key)
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
